GEMINI_API_KEY=
OPENROUTER_API_KEY=
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
# Render persistent disk path for SQLite. Mount a Render disk at /data or use PostgreSQL via DATABASE_URL.
SQLITE_PATH=/data/scholr.db
DATABASE_URL=
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app
